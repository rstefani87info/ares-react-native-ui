  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "lint": "eslint .",
    "start": "react-native start",
    "test": "jest",
    "build:ios": "xcodebuild -workspace ios/YourProject.xcworkspace -scheme YourProject -configuration Release -sdk iphoneos -archivePath ios/build/YourProject.xcarchive archive && xcodebuild -exportArchive -archivePath ios/build/YourProject.xcarchive -exportOptionsPlist ios/YourProject/Info.plist -exportPath ios/build",
    "build:android": "cd android && ./gradlew assembleRelease",
    "deploy:ios": "fastlane ios deploy",
    "deploy:android": "fastlane android deploy"
  },
  "eslintConfig": {
    "root": true,
    "extends": "@react-native",
    "rules": {
      "react/react-in-jsx-scope": "off",
      "react/jsx-uses-react": "off"
    },
    "parserOptions": {
      "requireConfigFile": false,
      "babelOptions": {
        "presets": [
          "@react-native/babel-preset"
        ]
      }
    }
  },
  "jest": {
    "preset": "react-native",
    "testMatch": [
      "**/test/**/*.test.cjs"
    ],
    "transform": {
      "^.+\\.(js|jsx|ts|tsx)$": "babel-jest"
    },
    "moduleNameMapper": {
      "^@ares/react-native-ui$": "<rootDir>/index.js",
      "^@ares/react-native-ui/(.*)$": "<rootDir>/$1"
    },
    "transformIgnorePatterns": [
      "node_modules/(?!(react-native|@react-native|@react-navigation|react-native-gesture-handler|react-native-modal|react-native-reanimated|react-native-reanimated-carousel|react-native-vector-icons)/)"
    ]
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-native": ">=0.76.0",
    "react-native-gesture-handler": ">=2.0.0",
    "react-native-reanimated": ">=3.0.0"
  },
